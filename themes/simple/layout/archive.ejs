<!-- 引入头部组件 -->
<%- partial('_partial/header') %>

<!-- 归档页标题 -->
<h1 class="archive-title">
  <% if (page.year) { %>
    <%= page.year %>年<% if (page.month) { %><%= page.month %>月<% } %>归档
  <% } else { %>
    归档
  <% } %>
</h1>

<!-- 分类筛选栏 -->
<div class="category-filter">
  <h3 class="filter-title">分类</h3>
  <div class="filter-tags">
    <% site.categories.each(function(category) { %>
      <button class="filter-tag" data-category="<%= category.name %>"><%= category.name %></button>
    <% }) %>
  </div>
</div>

<!-- 归档博文时间轴 -->
<% if (site.posts.length) { %>
  <div class="timeline-container">
    <!-- 时间轴内容 -->
    <div class="timeline-content-wrapper">
    <% var currentYear = null; %>
    <% site.posts.sort('date', -1).each(function(post, index) { %>
      <% if (!post.hidden) { %>
      <% var postYear = post.date.format('YYYY'); %>
      <% if (currentYear !== postYear) { %>
        <% currentYear = postYear; %>
        <!-- 年份标题 -->
        <div class="timeline-year">
          <span class="year-label"><%= currentYear %></span>
        </div>
        <!-- 年份时间轴开始 -->
        <div class="timeline-year-section">
      <% } %>
      
      <!-- 博文时间轴项 -->
      <div class="timeline-item" data-categories="<%= post.categories && post.categories.length ? post.categories.toArray().map(cat => cat.name).join(',') : 'uncategorized' %>">
        <!-- 时间轴节点 -->
        <div class="timeline-node"></div>
        <!-- 时间轴内容 -->
        <div class="timeline-content">
          <!-- 发布日期 -->
          <span class="timeline-date"><%= post.date.format('M/D') %></span>
          <!-- 博文标题 -->
          <a href="<%= post.permalink %>" class="timeline-link"><%= post.title %></a>
          <!-- 分类信息 -->
          <% if (post.categories && post.categories.length) { %>
            <span class="timeline-category">
              <%= post.categories.toArray()[0].name %>
            </span>
          <% } %>
        </div>
      </div>
      
      <% if (index < site.posts.length - 1) { %>
        <% var nextPost = site.posts.toArray()[index + 1]; %>
        <% var nextYear = nextPost.date.format('YYYY'); %>
        <% if (currentYear !== nextYear) { %>
          </div><!-- 年份时间轴结束 -->
        <% } %>
      <% } else { %>
        </div><!-- 最后一个年份时间轴结束 -->
      <% } %>
      <% } %>
    <% }) %>
    </div>
  </div>
<% } else { %>
  <div class="empty-tip">暂无归档博文</div>
<% } %>

<!-- 分类筛选脚本 -->
<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 检查是否为移动端
    const isMobile = window.innerWidth <= 768;
    if (isMobile) {
      // 移动端保持分类筛选功能
      // 不需要隐藏分类筛选栏，因为CSS已经处理了响应式布局
    }

    const filterTags = document.querySelectorAll('.filter-tag');
    const timelineItems = document.querySelectorAll('.timeline-item');
    let selectedCategories = [];

    // 初始化动画样式
    timelineItems.forEach(item => {
      item.style.transition = 'all 0.5s ease';
      item.style.opacity = '1';
      item.style.transform = 'translateY(0)';
    });

    // 筛选文章
    function filterPosts() {
      timelineItems.forEach(item => {
        const categories = item.dataset.categories.split(',');
        const isVisible = selectedCategories.length === 0 || selectedCategories.some(category => categories.includes(category));

        if (isVisible) {
          // 显示文章，添加上浮动画
          item.style.display = 'block';
          // 先设置初始状态
          item.style.opacity = '0';
          item.style.transform = 'translateY(20px)';
          // 触发重排
          item.offsetHeight;
          // 然后添加动画
          item.style.opacity = '1';
          item.style.transform = 'translateY(0)';
        } else {
          // 隐藏文章，添加渐隐动画
          item.style.opacity = '0';
          item.style.transform = 'translateY(20px)';
          setTimeout(() => {
            item.style.display = 'none';
          }, 500);
        }
      });
    }

    // 处理分类标签点击
    filterTags.forEach(tag => {
      tag.addEventListener('click', function() {
        const category = this.dataset.category;

        // 切换当前分类的选中状态
        const index = selectedCategories.indexOf(category);
        if (index > -1) {
          // 取消选择
          selectedCategories.splice(index, 1);
          this.classList.remove('active');
        } else {
          // 选择分类
          selectedCategories.push(category);
          this.classList.add('active');
        }

        // 执行筛选
        filterPosts();
      });
    });
  });
</script>

<!-- 引入页脚组件 -->
<%- partial('_partial/footer') %>