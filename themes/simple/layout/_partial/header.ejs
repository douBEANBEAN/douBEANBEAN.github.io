<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <!-- 适配移动端 -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <!-- 引入思源宋体 -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@400;700;900&display=swap" rel="stylesheet">
  <!-- 站点标题：优先取文章标题，无则取站点标题 -->
  <title><%= page.title || config.title %></title>
  <!-- 引入核心样式（绝对路径，适配 GitHub Pages） -->
  <link rel="stylesheet" href="/css/reset.css">
  <link rel="stylesheet" href="/css/variables.css">
  <link rel="stylesheet" href="/css/layout.css">
  <link rel="stylesheet" href="/css/nav.css">
  <link rel="stylesheet" href="/css/home.css">
  <link rel="stylesheet" href="/css/post.css">
  <link rel="stylesheet" href="/css/archive.css">
  <link rel="stylesheet" href="/css/sidebar.css">
  <link rel="stylesheet" href="/css/markdown.css">
  <link rel="stylesheet" href="/css/themes.css">
  <link rel="stylesheet" href="/css/responsive.css">
  <!-- 网站图标 -->
  <link rel="icon" type="image/x-icon" href="/favicon/favicon.ico">
  <link rel="shortcut icon" type="image/x-icon" href="/favicon/favicon.ico">
</head>
<body>
  <!-- 导航栏容器 -->
  <nav class="navbar">
    <div class="nav-container">
      <!-- 站点名称 -->
      <div class="site-name"><%= config.title %></div>
      <!-- 汉堡菜单按钮（移动端） -->
      <button class="menu-toggle" id="menu-toggle">
        <span class="menu-icon"></span>
        <span class="menu-icon"></span>
        <span class="menu-icon"></span>
      </button>
      <!-- 导航菜单 -->
      <ul class="nav-menu">
        <!-- 主页：跳转到根目录 -->
        <li class="nav-item"><a href="/" class="nav-link">主页</a></li>
        <!-- 归档：跳转到归档页 -->
        <li class="nav-item"><a href="/archives/" class="nav-link">归档</a></li>
        <!-- 关于：跳转到关于页 -->
        <li class="nav-item"><a href="/about/" class="nav-link">关于</a></li>
      </ul>
    </div>
  </nav>
  
  <!-- 侧边栏（移动端） -->
  <div class="sidebar" id="sidebar">
    <div class="sidebar-container">
      <!-- 关闭按钮 -->
      <button class="sidebar-close" id="sidebar-close">×</button>
      <!-- 侧边栏菜单 -->
      <ul class="sidebar-menu">
        <!-- 主页：跳转到根目录 -->
        <li class="sidebar-item"><a href="/" class="sidebar-link">主页</a></li>
        <!-- 归档：跳转到归档页 -->
        <li class="sidebar-item"><a href="/archives/" class="sidebar-link">归档</a></li>
        <!-- 关于：跳转到关于页 -->
        <li class="sidebar-item"><a href="/about/" class="sidebar-link">关于</a></li>
      </ul>
      
      <!-- 文章目录（仅在文章页显示） -->
      <% if (page.type === 'post' && page.toc && page.toc.length) { %>
        <div class="sidebar-toc">
          <div class="sidebar-toc-title">文章目录</div>
          <ul class="sidebar-toc-list">
            <li class="sidebar-toc-item"><a href="#top" class="sidebar-toc-link">始</a></li>
            <% page.toc.forEach(function(item) { %>
              <li class="sidebar-toc-item sidebar-toc-level-<%= item.level %>">
                <a href="#<%= item.id %>" class="sidebar-toc-link"><%= item.text %></a>
              </li>
            <% }) %>
            <li class="sidebar-toc-item"><a href="#bottom" class="sidebar-toc-link">末</a></li>
          </ul>
        </div>
      <% } %>
    </div>
  </div>
  
  <!-- 遮罩层 -->
  <div class="overlay" id="overlay"></div>
  <!-- 内容容器：留给子模板填充 -->
  <main class="content-container">