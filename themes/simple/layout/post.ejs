<!-- 引入头部组件 -->
<%- partial('_partial/header') %>

<!-- 关键：先判断 page 变量是否存在 -->
<% if (typeof page === 'undefined' || !page.title) { %>
  <div class="empty-tip" style="text-align:center; padding: 50px 0;">
    _(:3」∠)_诶呀，文章不存在呢
  </div>
<% } else { %>
  <!-- 单篇博文详情容器 -->
  <div class="post-detail-container">
    <!-- 目录导航 -->
    <div class="toc-container">
      <div class="toc-title">目录</div>
      <ul class="toc-list">
        <li class="toc-item toc-top"><a href="#top">始</a></li>
        <!-- 手动解析content生成TOC -->
        <% if (page.content) { %>
          <% var content = page.content; %>
          <% var headings = content.match(/<h([1-3])(.*?)id="([^"]+)"(.*?)>(.*?)<\/h[1-3]>/g); %>
          <% if (headings) { %>
            <% headings.forEach(function(heading) { %>
              <% var level = heading.match(/<h([1-3])/)[1]; %>
              <% var id = heading.match(/id="([^"]+)"/)[1]; %>
              <% var text = heading.match(/>(.*?)<\/h[1-3]>/)[1].replace(/<[^>]*>/g, ''); %>
              <li class="toc-item toc-level-<%= level %>">
                <a href="#<%= id %>"><%= text %></a>
              </li>
            <% }) %>
          <% } else { %>
            <li class="toc-item"><a href="#">无标题</a></li>
          <% } %>
        <% } else { %>
          <li class="toc-item"><a href="#">无内容</a></li>
        <% } %>
        <li class="toc-item toc-bottom"><a href="#bottom">末</a></li>
      </ul>
    </div>
    <!-- 博文内容 -->
    <div class="post-detail">
      <a id="top"></a>
      <!-- 博文标题 -->
      <h1 class="post-detail-title"><%= page.title %></h1>
      <!-- 博文元信息 -->
      <div class="post-detail-meta">
        <%= page.date ? page.date.format('YYYY-MM-DD') : '' %>
         <br>
        <% if (page.content) { %>
            <% var plainText = page.content.replace(/<[^>]*>/g, ''); %>
            <%= plainText.length %>字 · <%= Math.ceil(plainText.length / 300) %>分钟
          <% } %>
        <% if (page.categories && page.categories.length) { %>
          · 
          <% page.categories.each(function(category, i) { %>
            <%= category.name %><% if (i < page.categories.length - 1) { %>, <% } %>
          <% }) %>
        <% } %>
      </div>
      <!-- 博文正文（解析 Markdown） -->
      <div class="post-detail-content"><%- page.content.replace(/^[\s\S]*?<span id="more"><\/span>/, '') %></div>
      <a id="bottom"></a>
      
      <!-- 评论系统 -->
      <div class="comment-section">
        <h3 class="comment-title">评论</h3>
        <div id="momo-comment"></div>
      </div>
    </div>
  </div>
  
  <!-- 评论系统脚本 -->
  <script src="https://cdn.jsdelivr.net/npm/@motues/momo-comment/dist/momo-comment.min.js"></script>
  <script>
    momo.init({
      el: 'momo-comment',
      title: '<%= page.title %>',
      slugid: '<%= page.path %>',
      lang: 'zh-cn',
      apiUrl: 'https://api-momo.motues.top'
    });
  </script>
  
  <!-- 目录导航脚本 -->
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // 动态生成TOC
      const tocList = document.querySelector('.toc-list');
      const headings = document.querySelectorAll('h1, h2, h3');
      
      // 清空TOC列表（保留"始"和"末"）
      const tocTop = tocList.querySelector('.toc-top');
      const tocBottom = tocList.querySelector('.toc-bottom');
      tocList.innerHTML = '';
      tocList.appendChild(tocTop);
      
      // 添加标题到TOC
      headings.forEach(function(heading) {
        const id = heading.getAttribute('id');
        if (id) {
          const text = heading.textContent;
          const level = heading.tagName.substring(1);
          const li = document.createElement('li');
          li.className = `toc-item toc-level-${level}`;
          const a = document.createElement('a');
          a.href = `#${id}`;
          a.textContent = text;
          li.appendChild(a);
          tocList.appendChild(li);
        }
      });
      
      // 添加"末"
      tocList.appendChild(tocBottom);
      
      // 滚动监听
      const tocItems = document.querySelectorAll('.toc-item a');
      
      window.addEventListener('scroll', function() {
        let current = '';
        
        headings.forEach(function(heading) {
          const headingTop = heading.offsetTop;
          if (window.scrollY >= headingTop - 100) {
            current = heading.getAttribute('id');
          }
        });
        
        // 更新目录高亮
        tocItems.forEach(function(item) {
          item.parentElement.classList.remove('active');
          if (item.getAttribute('href') === '#' + current) {
            item.parentElement.classList.add('active');
          }
        });
      });
      
      // 点击目录项平滑滚动
      tocItems.forEach(function(item) {
        item.addEventListener('click', function(e) {
          e.preventDefault();
          const targetId = this.getAttribute('href').substring(1);
          const targetElement = document.getElementById(targetId);
          if (targetElement) {
            window.scrollTo({
              top: targetElement.offsetTop - 80,
              behavior: 'smooth'
            });
          }
        });
      });
    });
  </script>
<% } %>

<!-- 引入页脚组件 -->
<%- partial('_partial/footer') %>