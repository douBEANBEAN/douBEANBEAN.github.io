<!-- 引入头部组件 -->
<%- partial('_partial/header') %>

<!-- 博文列表容器 -->
<div class="post-list">
  <!-- 遍历所有博文（按发布时间倒序） -->
  <% if (site.posts.length) { %>
    <% site.posts.sort('date', -1).each(function(post) { %>
      <% if (!post.hidden) { %>
      <!-- 单篇博文卡片 -->
      <a href="<%= post.permalink %>" class="post-card-link">
        <div class="post-card">
          <!-- 左侧内容 -->
          <div class="post-left">
            <!-- 博文标题 -->
            <h2 class="post-title"><%= post.title %></h2>
            <!-- 博文摘要（使用用户自定义摘要） -->
            <div class="post-excerpt"><%- post.excerpt %></div>
          </div>
          <!-- 右侧内容 -->
          <div class="post-right">
            <div class="post-date"><%= post.date.format('YYYY-MM-DD') %></div>
            <div class="post-meta">
              <% if (post.content) { %>
                <% var plainText = post.content.replace(/<[^>]*>/g, ''); %>
                <%= plainText.length %>字 · <%= Math.ceil(plainText.length / 300) %>分钟
              <% } %>
              <% if (post.categories && post.categories.length) { %>
                <% if (post.content) { %> · <% } %>
                <%= post.categories.toArray()[0].name %>
              <% } %>
            </div>
          </div>
        </div>
      </a>
      <% } %>
    <% }) %>
  <% } else { %>
    <!-- 无博文时的提示 -->
    <div class="empty-tip">暂无文章，敬请期待！ヾ(•ω•`)o</div>
  <% } %>
</div>

<!-- 引入页脚组件 -->
<%- partial('_partial/footer') %>